# ── 候选人隐私:绝不进仓库 ──
# 简历 PDF(只存本地、可转发,但不上传)
*.pdf
# 各岗「待定/」中转目录的内容(保留空目录占位)
**/待定/*
!**/待定/.gitkeep

# ── 猎聘登录态 / 锁(本就在 homedir,这里防误放) ──
.search-lock
.liepin-cli/

# ── 依赖 / 系统噪音 ──
node_modules/
.DS_Store
Thumbs.db
*.log

